{
    "compilerOptions": {
        "strict": true,
        "noEmit": true,
        "module": "esnext",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "stableTypeOrdering": true,
        "target": "es2022",
        "lib": ["dom", "dom.iterable", "es2022"],
        "jsx": "react-jsx",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "paths": {
            "@client/*": ["${configDir}/client/*"],
            "@reactivated": ["${configDir}/client/generated/index.tsx"],
            "@reactivated/*": ["${configDir}/client/generated/*"]
        }
    }
}
